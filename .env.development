# Configuração Padrão para Desenvolvimento

NODE_ENV=development
PORT=3001
HOST=localhost

# Deriv API (Sandbox/Testing)
DERIV_API_BASE_URL=https://api.derivws.com
DERIV_WS_PUBLIC_URL=wss://api.derivws.com/trading/v1/options/ws/public
DERIV_WS_AUTH_URL=wss://api.derivws.com/trading/v1/options/ws
DERIV_AUTH_BASE_URL=https://auth.deriv.com/oauth2

# ⚠️ Substitua com suas credenciais de teste
DERIV_CLIENT_ID=test_client_id_here
DERIV_CLIENT_SECRET=test_client_secret_here
DERIV_REDIRECT_URI=http://localhost:3001/api/auth/callback
DERIV_APP_ID=test_app_id_here

# Frontend URLs
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://yourdomain.com

# Redis Configuration (opcional em dev)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Security (mudar em produção!)
JWT_SECRET=dev-secret-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_SUBSCRIPTIONS=100
WS_RECONNECT_MAX_ATTEMPTS=5
WS_RECONNECT_DELAY=1000

# Rate Limiting (permissivo em dev)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
