# ============================================
# Deriv Trading Backend - Production Environment
# ============================================

# Server Configuration
NODE_ENV=production
PORT=8080
HOST=0.0.0.0

# Deriv API Configuration
# Get these from your Deriv account at https://developers.deriv.com
DERIV_CLIENT_ID=your_client_id_here
DERIV_CLIENT_SECRET=your_client_secret_here
DERIV_APP_ID=your_app_id_here
DERIV_API_BASE_URL=https://api.derivws.com
DERIV_WS_PUBLIC_URL=wss://api.derivws.com/trading/v1/options/ws/public
DERIV_AUTH_BASE_URL=https://auth.deriv.com/oauth2
DERIV_REDIRECT_URI=https://yourdomain.com/api/auth/callback

# Frontend Configuration
FRONTEND_URL=https://yourdomain.com
FRONTEND_PROD_URL=https://yourdomain.com

# Redis Configuration (optional - will use in-memory store if unavailable)
REDIS_HOST=redis.railway.app
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# Security Configuration
JWT_SECRET=generate_a_secure_random_string_here_min_32_chars
CORS_ORIGIN=https://yourdomain.com

# Logging Configuration
LOG_LEVEL=info
# Logs will be sent to stdout in production (Railway compatible)

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_SUBSCRIPTIONS=100
WS_RECONNECT_MAX_ATTEMPTS=5
WS_RECONNECT_DELAY=1000

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
