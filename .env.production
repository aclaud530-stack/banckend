# Configuração para Produção

NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Deriv API (Production)
DERIV_API_BASE_URL=https://api.derivws.com
DERIV_WS_PUBLIC_URL=wss://api.derivws.com/trading/v1/options/ws/public
DERIV_WS_AUTH_URL=wss://api.derivws.com/trading/v1/options/ws
DERIV_AUTH_BASE_URL=https://auth.deriv.com/oauth2

# ⚠️ Substitua com suas credenciais de PRODUÇÃO
DERIV_CLIENT_ID=your_production_client_id
DERIV_CLIENT_SECRET=your_production_client_secret
DERIV_REDIRECT_URI=https://yourdomain.com/api/auth/callback
DERIV_APP_ID=your_production_app_id

# Frontend URLs (Production)
FRONTEND_URL=https://yourdomain.com
FRONTEND_PROD_URL=https://yourdomain.com

# Redis Configuration (RECOMENDADO em produção)
REDIS_HOST=redis-host.example.com
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=secure_redis_password

# Security (GERAR NOVO EM PRODUÇÃO!)
JWT_SECRET=generate_a_strong_random_secret_key_here

# CORS (Apenas domínios confiáveis)
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/deriv-api/app.log

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_SUBSCRIPTIONS=100
WS_RECONNECT_MAX_ATTEMPTS=5
WS_RECONNECT_DELAY=1000

# Rate Limiting (Mais restritivo em prod)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring/APM (Opcional)
# SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
# NEW_RELIC_LICENSE_KEY=your_new_relic_key
# DATADOG_API_KEY=your_datadog_key
